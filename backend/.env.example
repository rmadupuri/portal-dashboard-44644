# Server Configuration
PORT=5001
NODE_ENV=development

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:8080

# cBioPortal API
CBIOPORTAL_API_URL=https://www.cbioportal.org/api

# ClickHouse — read-only genomics analytics
# (using cgds_public_blue for now, but will check for production db color and switch in the future)
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=
CLICKHOUSE_DATABASE=cgds_public_blue
CLICKHOUSE_USERNAME=
CLICKHOUSE_PASSWORD=

# Postgres — app data (users + submissions)
PGHOST=
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=postgres
# SSL: for managed/cloud Postgres set verify-full and point at the CA cert
# (path is relative to the backend/ directory). Leave both blank for local dev.
PGSSLMODE=verify-full
PGSSLROOTCERT=your-ca-certificate.pem
# PG_POOL_MAX=10

# Keycloak (OIDC) — realm issuer; backend validates access tokens against its JWKS
KEYCLOAK_ISSUER=http://localhost:8081/realms/dashboard
# Expected token audience (the client this API trusts).
KEYCLOAK_AUDIENCE=
