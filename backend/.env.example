# Server Configuration
PORT=5001
NODE_ENV=development

# JWT Secret (generate a random string)
JWT_SECRET=
JWT_EXPIRE=7d

# OAuth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Backend URL (for OAuth callbacks)
BACKEND_URL=http://localhost:5001

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:8080

# Super user emails (comma-separated)
SUPER_USER_EMAILS=

# cBioPortal API
CBIOPORTAL_API_URL=https://www.cbioportal.org/api

# ClickHouse (using cgds_public_blue for now, but will check for production db color and switch in the future)
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=
CLICKHOUSE_DATABASE=cgds_public_blue
CLICKHOUSE_USERNAME=
CLICKHOUSE_PASSWORD=
